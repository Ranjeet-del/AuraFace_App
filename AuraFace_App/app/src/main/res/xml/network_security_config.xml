<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- By default, disallow cleartext (HTTP) traffic for better security (Play Store standard) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext ONLY for development servers (Change these to HTTPS for production) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.113.156.225</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.11.219.225</domain>
    </domain-config>
</network-security-config>
