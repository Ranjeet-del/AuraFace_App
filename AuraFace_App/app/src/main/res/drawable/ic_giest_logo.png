  <style>
  #privacy-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #1a1a2e;
    color: #eee;
    padding: 20px;
    z-index: 10000;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.3);
    font-size: 14px;
    display: none;
  }
  #privacy-banner.show { display: block; }
  #privacy-banner .pb-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 15px;
  }
  #privacy-banner .pb-text { flex: 1; min-width: 300px; }
  #privacy-banner .pb-text a { color: #6eb5ff; }
  #privacy-banner .pb-buttons { display: flex; gap: 10px; flex-wrap: wrap; }
  #privacy-banner button {
    padding: 12px 24px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
  }
  #privacy-banner .pb-accept {
    background: #4CAF50;
    color: white;
  }
  #privacy-banner .pb-decline {
    background: #555;
    color: white;
  }
  #privacy-banner button:hover { opacity: 0.9; }
  @media (max-width: 768px) {
    #privacy-banner .pb-content { flex-direction: column; text-align: center; }
    #privacy-banner .pb-buttons { width: 100%; justify-content: center; }
  }
  </style>

  <script type="3510f92ae7869de716cd2c16-text/javascript">
  $(document).ready(function(){
    $('#burger-menu').click(function(){
      $(this).toggleClass('active');
      $('#header-nav').toggleClass('open');
    });

    // Privacy consent management
    var privacyRegion = 'none';
    var showBanner = false;

    function setConsentCookie(value) {
      var d = new Date();
      d.setTime(d.getTime() + (365*24*60*60*1000));
      document.cookie = "privacy_consent=" + value + ";expires=" + d.toUTCString() + ";path=/;SameSite=Lax";
    }

    function updateTaboolaConsent(accepted) {
      window._taboola = window._taboola || [];
      if (privacyRegion === 'gdpr') {
        _taboola.push({ cex: accepted ? 'true' : 'false' });
      } else if (privacyRegion === 'us_state') {
        _taboola.push({ cdns: accepted ? 'false' : 'true' });
      }
    }

    function handleConsent(accepted) {
      setConsentCookie(accepted ? 'accepted' : 'declined');
      updateTaboolaConsent(accepted);
      $('#privacy-banner').removeClass('show');
      if (accepted) {
        // Reload ads/tracking if needed
        if (typeof freestar !== 'undefined' && freestar.newAdSlots) {
          freestar.newAdSlots(freestar.config.enabled_slots);
        }
      }
    }

    if (showBanner) {
      $('#privacy-banner').addClass('show');
    }

    $('#pb-accept').click(function() { handleConsent(true); });
    $('#pb-decline').click(function() { handleConsent(false); });

    // Privacy Manager button (in footer)
    $('#pmLink').click(function() {
      $('#privacy-banner').addClass('show');
    });
  });
  </script>
